+			FROM  user_message  a 
+			LEFT JOIN user_info b ON b.uid=a.senduser
+			WHERE a.receiveuser =#{receiveuser}  and  isread=0     ORDER BY a.createdate ASC  
+	</select>	
+		
+	
+
+	<select id="queryObject" resultType="com.ziyue.imentity.entity.Vo.UserMessageEntity">
